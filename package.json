{
  "name": "sunity-api",
  "version": "1.0.0",
  "description": "Express API scaffold with Drizzle ORM",
  "keywords": [],
  "homepage": "https://github.com/sayyidrafeed/sunity-api#readme",
  "bugs": {
    "url": "https://github.com/sayyidrafeed/sunity-api/issues"
  },
  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sayyidrafeed/sunity-api.git"
  },
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "lint": "oxlint",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "fl": "bun run format && bun run lint",
    "check": "tsgo --noEmit"
  },
  "dependencies": {
    "better-auth": "^1.6.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@typescript/native-preview": "^7.0.0-dev.20260207.1",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20"
  }
}
